# =========================
# ENTORNO DE LA APP
# =========================
# Modo de ejecucion del backend
NODE_ENV=production

# Puerto interno donde corre la API
PORT=3000

# =========================
# BASE DE DATOS
# =========================
# Nombre de la base de datos
DB_NAME=bodega_ecole

# Usuario de MySQL
DB_USERNAME=bodega_user
DB_USER=bodega_user

# Password de MySQL
# Ambos valores deben ser iguales por compatibilidad con el proyecto
DB_PASSWORD=TuPasswordSeguraAqui123!
DB_PASS=TuPasswordSeguraAqui123!

# Host de MySQL. En Docker local es "mysql"; en la nube (Aiven) es algo
# como "mysql-xxxx.aivencloud.com".
DB_HOST=mysql

# Puerto interno de MySQL (local 3306; en Aiven suele ser un número alto).
DB_PORT=3306

# Puerto expuesto en la instancia
DB_PORT_EXTERNAL=3307

# Conexión cifrada (SSL). En LOCAL déjalo en false; en la NUBE ponlo en true.
DB_SSL=false

# Crear las tablas automáticamente al arrancar (TypeORM synchronize).
# En LOCAL déjalo en false (usamos Flyway). En la NUBE ponlo en true la
# PRIMERA vez para que cree el esquema, luego puedes volver a false.
DB_SYNC=false

# =========================
# AUTENTICACION JWT
# =========================
# Reemplaza por un secreto largo y seguro
JWT_SECRET=tu_jwt_secret_super_seguro_reemplaza_esto

# Duracion del token
JWT_EXPIRES_IN=1d

# =========================
# USUARIO ADMIN INICIAL
# =========================
ADMIN_EMAIL=admin@bodega.cl
ADMIN_PASSWORD=TuAdminPasswordSegura123!
ADMIN_NOMBRE=Administrador

# =========================
# CORS (qué webs pueden llamar a la API)
# =========================
# Lista separada por comas. En producción agrega aquí la URL del frontend
# en Vercel, por ejemplo: https://mi-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# =========================
# URL PUBLICA
# =========================
API_URL=http://tu-ip-publica-o-dominio:3000
